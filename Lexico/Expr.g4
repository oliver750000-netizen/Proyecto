//OPERADORES
ASIG: '=';
SUMA_ASIG: '+=';
RESTA_ASIG: '-=';
MULTI_ASIG: '*=';
DIVI_ASIG: '/=';
MODU_ASIG: '%=';
AND_ASIG: '&=';
OR_ASIG: '|=';
XOR_ASIG: '^=';
DESPLA_IZQ_ASIG: '<<=';
DESPLA_DER_ASIG: '>>=';
DESPLA_DER_SIN_SIGNO_ASIG: '>>>=';
MAS: '+';
MENOS: '-';
POR: '*';
DIVI: '/';
PORSE: '%';
INCRE: '++';
DISMI: '--';
IGUAL_QUE: '==';
DIFER_DE: '!=';
MENOR: '<';
MAYOR: '>';
MENOR_ASIG: '<=';
MAYOR_ASIG: '>=';
AND: '&&';
OR: '||';
NOT: '!';
AND_BIT: '&';
OR_BIT: '|';
XOR: '^';
COMPLE: '~';
DESPL_IZQ: '<<';
DESPL_DER: '>>';
DESPL_DER_SIN_SIGNO: '>>>';
CONDI: '?';
SEPAR: ':';
LAMBDA: '->';
REFERENCIA: '::';

//SEPARADORES
PARE_IZQ: '(';
PARE_DER: ')';
LLAV_IZQ: '{';
LLAV_DER: '}';
CORC_IZQ: '[';
CORC_DER: ']';
PUNTO_COMA: ';';
COMA: ',';
PUNTO: '.';
VARARGS: '...';
ANOTACION: '@';
EXP_REGU: [a-zA-Z_$][a-zA-Z0-9_$]*;
NUM: [0-9]+;
NUM_REGU : [0-9]+ '.' [0-9]+ [fFdD]?;
CADENA: '"' ( '\\' . | ~["\\] )* '"';
REPRE_CHAR: '\'' ( '\\' . | ~['\\\r\n] ) '\'';
WS: [ \t\r\n]+ -> skip ;


