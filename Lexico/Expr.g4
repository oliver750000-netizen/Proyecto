grammar Expr;

root : expr EOF;

//
expr : EOF ;

//Palabras reservadas y palabras clave contextuales
SYSTEM: 'System';
OUT: 'out';
PRINT: 'print';
PRINTLN: 'println';
MAIN: 'main';
STRING: 'String';
OBJECT: 'Object';
MATH: 'Math';
INTEGER: 'Integer';
CHARACTER: 'Character';
