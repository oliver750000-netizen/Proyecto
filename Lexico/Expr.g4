IOEXCEPTION: 'IOException';
CONNECTION: 'Connection';
STATEMENT: 'Statement';
PREPAREDSTATEMENT: 'PreparedStatement';
RESULTSET: 'ResultSet';
DRIVERMANAGER: 'DriverManager';
